# PWA install icons — raster fallbacks needed for Android Chrome's install
# check (it ignores SVG-only manifest icons).
!/client/public/icons/*.png

# ROMs (user-supplied real ROMs go here, not committed). Test ROM is whitelisted below.
/server/roms/*
!/server/roms/.gitkeep
!/server/roms/README.md
!/server/roms/test-*

/client/dist/
/server/dist/
.cache/
*.tsbuildinfo

# Persistent save data — created at runtime, never committed.
/server/data/
/data/

# Brainstorming session scratch (mockups, transient state).
.superpowers/
